@prefix pa: <https://faw.example.local/project-approval#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pa:ProjectApprovalOntology a owl:Ontology ;
  rdfs:label "项目立项自动审批系统" .

pa:ProjectApprovalSystem a owl:Class ;
  rdfs:label "项目审批系统" ;
  rdfs:comment "覆盖前端、后端、运行时资产与分发包的完整审批平台。" .

pa:ProjectApprovalProject a owl:Class ;
  rdfs:label "立项审批项目" ;
  rdfs:comment "项目审批场景下的根实体。" .

pa:ProjectContent a owl:Class ;
  rdfs:label "项目内容" ;
  rdfs:comment "项目背景、目标、方案等申报内容。" .

pa:ProjectOKR a owl:Class ;
  rdfs:label "项目OKR" ;
  rdfs:comment "项目目标、关键结果及相关信息。" .

pa:ProjectScope a owl:Class ;
  rdfs:label "项目范围" ;
  rdfs:comment "业务范围与系统范围信息。" .

pa:ArchitectureReview a owl:Class ;
  rdfs:label "架构评审" ;
  rdfs:comment "业务、数据、技术、安全等架构评审维度。" .

pa:ProjectValuePlan a owl:Class ;
  rdfs:label "项目价值与计划" ;
  rdfs:comment "项目价值模型、里程碑及相关计划信息。" .

pa:OrganizationBudget a owl:Class ;
  rdfs:label "组织与预算" ;
  rdfs:comment "组织架构、预算与费用信息。" .

pa:ReviewRule a owl:Class ;
  rdfs:label "评审规则" ;
  rdfs:comment "从规则矩阵中抽取的审批规则。" .

pa:ApiEndpoint a owl:Class ;
  rdfs:label "远程接口" ;
  rdfs:comment "项目数据来源接口。" .

pa:BackendApiRoute a owl:Class ;
  rdfs:label "后端路由" ;
  rdfs:comment "本地审批系统暴露的 HTTP 路由。" .

pa:FrontendPage a owl:Class ;
  rdfs:label "前端页面" ;
  rdfs:comment "系统面向用户的前端页面。" .

pa:BackendService a owl:Class ;
  rdfs:label "后端服务" ;
  rdfs:comment "系统中的后端模块或运行服务。" .

pa:RuntimeArtifact a owl:Class ;
  rdfs:label "运行时资产" ;
  rdfs:comment "系统运行过程中生成或依赖的文件与目录。" .

pa:ConfigurationFile a owl:Class ;
  rdfs:label "配置文件" ;
  rdfs:comment "系统运行依赖的配置输入文件。" .

pa:ApprovalSkill a owl:Class ;
  rdfs:label "审批技能" ;
  rdfs:comment "按审批 tab 聚合生成的技能单元。" .

pa:DeploymentPackage a owl:Class ;
  rdfs:label "部署包" ;
  rdfs:comment "面向目标操作系统的分发包。" .

pa:ProjectCategory a owl:Class ;
  rdfs:label "项目品类" ;
  rdfs:comment "适用的项目分类。" .

pa:ApprovalDecision a owl:Class ;
  rdfs:label "审批结论" ;
  rdfs:comment "审批结果等级。" .

pa:hasFrontendPage a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalSystem ;
  rdfs:range pa:FrontendPage ;
  rdfs:label "包含前端页面" .

pa:exposesBackendRoute a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalSystem ;
  rdfs:range pa:BackendApiRoute ;
  rdfs:label "暴露后端路由" .

pa:usesBackendService a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalSystem ;
  rdfs:range pa:BackendService ;
  rdfs:label "使用后端服务" .

pa:persistsArtifact a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalSystem ;
  rdfs:range pa:RuntimeArtifact ;
  rdfs:label "持久化运行资产" .

pa:usesConfigurationFile a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalSystem ;
  rdfs:range pa:ConfigurationFile ;
  rdfs:label "使用配置文件" .

pa:loadsApprovalSkill a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalSystem ;
  rdfs:range pa:ApprovalSkill ;
  rdfs:label "加载审批技能" .

pa:packagedAs a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalSystem ;
  rdfs:range pa:DeploymentPackage ;
  rdfs:label "打包为" .

pa:hasContent a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:ProjectContent ;
  rdfs:label "包含项目内容" .

pa:hasOKR a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:ProjectOKR ;
  rdfs:label "包含项目OKR" .

pa:hasScope a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:ProjectScope ;
  rdfs:label "包含项目范围" .

pa:hasArchitectureReview a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:ArchitectureReview ;
  rdfs:label "包含架构评审" .

pa:hasValuePlan a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:ProjectValuePlan ;
  rdfs:label "包含价值与计划" .

pa:hasOrganizationBudget a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:OrganizationBudget ;
  rdfs:label "包含组织与预算" .

pa:usesApiEndpoint a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:ApiEndpoint ;
  rdfs:label "使用远程接口" .

pa:appliesRule a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:ReviewRule ;
  rdfs:label "应用评审规则" .

pa:targetsCategory a owl:ObjectProperty ;
  rdfs:domain pa:ReviewRule ;
  rdfs:range pa:ProjectCategory ;
  rdfs:label "适用品类" .

pa:hasDecisionLevel a owl:ObjectProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range pa:ApprovalDecision ;
  rdfs:label "具有审批结论" .

pa:systemEntryUrl a owl:DatatypeProperty ;
  rdfs:domain pa:ProjectApprovalSystem ;
  rdfs:range xsd:string ;
  rdfs:label "系统入口地址" .

pa:projectTitle a owl:DatatypeProperty ;
  rdfs:domain pa:ProjectApprovalProject ;
  rdfs:range xsd:string ;
  rdfs:label "项目标题" .

pa:sectionSummary a owl:DatatypeProperty ;
  rdfs:domain pa:ProjectContent ;
  rdfs:range xsd:string ;
  rdfs:label "内容摘要" .

pa:reviewPointName a owl:DatatypeProperty ;
  rdfs:domain pa:ReviewRule ;
  rdfs:range xsd:string ;
  rdfs:label "评审点名称" .

pa:ruleText a owl:DatatypeProperty ;
  rdfs:domain pa:ReviewRule ;
  rdfs:range xsd:string ;
  rdfs:label "规则文本" .

pa:apiPath a owl:DatatypeProperty ;
  rdfs:domain pa:ApiEndpoint ;
  rdfs:range xsd:string ;
  rdfs:label "接口路径" .

pa:routePath a owl:DatatypeProperty ;
  rdfs:domain pa:FrontendPage ;
  rdfs:range xsd:string ;
  rdfs:label "路由路径" .

pa:componentName a owl:DatatypeProperty ;
  rdfs:domain pa:FrontendPage ;
  rdfs:range xsd:string ;
  rdfs:label "组件名称" .

pa:httpMethod a owl:DatatypeProperty ;
  rdfs:domain pa:BackendApiRoute ;
  rdfs:range xsd:string ;
  rdfs:label "请求方法" .

pa:handlerName a owl:DatatypeProperty ;
  rdfs:domain pa:BackendApiRoute ;
  rdfs:range xsd:string ;
  rdfs:label "处理函数" .

pa:modulePath a owl:DatatypeProperty ;
  rdfs:domain pa:BackendService ;
  rdfs:range xsd:string ;
  rdfs:label "模块路径" .

pa:serviceType a owl:DatatypeProperty ;
  rdfs:domain pa:BackendService ;
  rdfs:range xsd:string ;
  rdfs:label "服务类型" .

pa:artifactPath a owl:DatatypeProperty ;
  rdfs:domain pa:RuntimeArtifact ;
  rdfs:range xsd:string ;
  rdfs:label "资产路径" .

pa:artifactType a owl:DatatypeProperty ;
  rdfs:domain pa:RuntimeArtifact ;
  rdfs:range xsd:string ;
  rdfs:label "资产类型" .

pa:configPath a owl:DatatypeProperty ;
  rdfs:domain pa:ConfigurationFile ;
  rdfs:range xsd:string ;
  rdfs:label "配置路径" .

pa:configType a owl:DatatypeProperty ;
  rdfs:domain pa:ConfigurationFile ;
  rdfs:range xsd:string ;
  rdfs:label "配置类型" .

pa:skillTab a owl:DatatypeProperty ;
  rdfs:domain pa:ApprovalSkill ;
  rdfs:range xsd:string ;
  rdfs:label "技能页签" .

pa:skillRuleCount a owl:DatatypeProperty ;
  rdfs:domain pa:ApprovalSkill ;
  rdfs:range xsd:integer ;
  rdfs:label "技能规则数量" .

pa:packageType a owl:DatatypeProperty ;
  rdfs:domain pa:DeploymentPackage ;
  rdfs:range xsd:string ;
  rdfs:label "部署包类型" .

pa:packageEntry a owl:DatatypeProperty ;
  rdfs:domain pa:DeploymentPackage ;
  rdfs:range xsd:string ;
  rdfs:label "启动入口" .

pa:categoryGroup a owl:DatatypeProperty ;
  rdfs:domain pa:ProjectCategory ;
  rdfs:range xsd:string ;
  rdfs:label "品类分组" .

pa:decisionLabel a owl:DatatypeProperty ;
  rdfs:domain pa:ApprovalDecision ;
  rdfs:range xsd:string ;
  rdfs:label "结论标签" .

pa:System01 a owl:NamedIndividual , pa:ProjectApprovalSystem ;
  rdfs:label "项目立项自动审批系统" ;
  pa:systemEntryUrl "/ui/approval" ;
  pa:persistsArtifact pa:RuntimeArtifact01 ;
  pa:usesConfigurationFile pa:ConfigFile01 ;
  pa:usesConfigurationFile pa:ConfigFile02 ;
  pa:usesConfigurationFile pa:ConfigFile03 ;
  pa:usesConfigurationFile pa:ConfigFile04 ;
  pa:usesConfigurationFile pa:ConfigFile05 ;
  pa:usesConfigurationFile pa:ConfigFile06 ;
  pa:loadsApprovalSkill pa:ApprovalSkill01 ;
  pa:loadsApprovalSkill pa:ApprovalSkill02 ;
  pa:loadsApprovalSkill pa:ApprovalSkill03 ;
  pa:loadsApprovalSkill pa:ApprovalSkill04 ;
  pa:loadsApprovalSkill pa:ApprovalSkill05 ;
  pa:loadsApprovalSkill pa:ApprovalSkill06 ;
  pa:loadsApprovalSkill pa:ApprovalSkill07 ;
  pa:loadsApprovalSkill pa:ApprovalSkill08 ;
  pa:packagedAs pa:DeploymentPackage01 ;
  pa:packagedAs pa:DeploymentPackage02 .

