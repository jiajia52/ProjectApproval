# iwork / ITPM integration defaults
PROJECT_APPROVAL_IWORK_BASE_URL=https://prod-itpm.faw.cn/itpmNew/gateway/sop-itpm-service
PROJECT_APPROVAL_IWORK_IAM_URL=https://iwork.faw.cn/api-dev/dcp-base-sso/iamToken
PROJECT_APPROVAL_IWORK_TOKEN=
PROJECT_APPROVAL_IWORK_JSESSIONID=
PROJECT_APPROVAL_IWORK_USE_IAM=false
PROJECT_APPROVAL_IWORK_IAM_FULL_URL=
PROJECT_APPROVAL_IWORK_IAM_CODE=
PROJECT_APPROVAL_IWORK_CLIENT_ID=faw_qfc_sso
PROJECT_APPROVAL_IWORK_SECRET_PATH=iworkiamencrypt.client-secret
PROJECT_APPROVAL_IWORK_REDIRECT_URL=https://iwork.faw.cn/api-dev/dcp-base-sso/iamToken
PROJECT_APPROVAL_IWORK_INDEX_URL=https://iwork.faw.cn
PROJECT_APPROVAL_IWORK_TENANT_ID=YQJT
PROJECT_APPROVAL_IWORK_SYSTEM_ID=BA-0222
PROJECT_APPROVAL_IWORK_MENU_CODE=null
PROJECT_APPROVAL_IWORK_LOGO=iworkiamencrypt
PROJECT_APPROVAL_IWORK_STATE=123
PROJECT_APPROVAL_IWORK_TIMEOUT=20
PROJECT_APPROVAL_IWORK_VERIFY_SSL=true
PROJECT_APPROVAL_IWORK_CA_BUNDLE_PATH=
PROJECT_APPROVAL_IWORK_LANG=zh-cn
PROJECT_APPROVAL_IWORK_QFCSID=MS-0701
PROJECT_APPROVAL_IWORK_QFCTID=YQJT
PROJECT_APPROVAL_IWORK_QFC_USER_PARA={"systemId":"MS-0701","appCode":"MS-0701_APP_004"}

# backend runtime
PROJECT_APPROVAL_HOST=127.0.0.1
PROJECT_APPROVAL_PORT=8000
PROJECT_APPROVAL_RELOAD=true

# optional nacos config center
# turn on to load remote config from nacos before app startup
PROJECT_APPROVAL_NACOS_ENABLED=false
# supports host:port, http://host:port, or comma-separated server list (uses the first one)
PROJECT_APPROVAL_NACOS_SERVER_ADDR=127.0.0.1:8848
# only used when server addr has no scheme
PROJECT_APPROVAL_NACOS_SCHEME=http
PROJECT_APPROVAL_NACOS_NAMESPACE=
PROJECT_APPROVAL_NACOS_GROUP=DEFAULT_GROUP
PROJECT_APPROVAL_NACOS_DATA_ID=project-approval.env
# supported values: auto, dotenv, properties, json, yaml
PROJECT_APPROVAL_NACOS_FORMAT=auto
PROJECT_APPROVAL_NACOS_USERNAME=
PROJECT_APPROVAL_NACOS_PASSWORD=
PROJECT_APPROVAL_NACOS_TIMEOUT=5
PROJECT_APPROVAL_NACOS_VERIFY_SSL=true
# true: nacos values overwrite existing env/.env values
PROJECT_APPROVAL_NACOS_OVERRIDE=false
# true: startup fails immediately when nacos loading fails
PROJECT_APPROVAL_NACOS_FAIL_FAST=false

# nacos service registration + discovery
PROJECT_APPROVAL_NACOS_DISCOVERY_ENABLED=false
PROJECT_APPROVAL_NACOS_DISCOVERY_SERVICE_NAME=project-approval-api
PROJECT_APPROVAL_NACOS_DISCOVERY_IP=
PROJECT_APPROVAL_NACOS_DISCOVERY_PORT=8000
PROJECT_APPROVAL_NACOS_DISCOVERY_GROUP=DEFAULT_GROUP
PROJECT_APPROVAL_NACOS_DISCOVERY_CLUSTER=DEFAULT
PROJECT_APPROVAL_NACOS_DISCOVERY_NAMESPACE=
PROJECT_APPROVAL_NACOS_DISCOVERY_WEIGHT=1
PROJECT_APPROVAL_NACOS_DISCOVERY_EPHEMERAL=true
PROJECT_APPROVAL_NACOS_DISCOVERY_HEARTBEAT_INTERVAL=5
PROJECT_APPROVAL_NACOS_DISCOVERY_TIMEOUT=5
PROJECT_APPROVAL_NACOS_DISCOVERY_VERIFY_SSL=true
PROJECT_APPROVAL_NACOS_DISCOVERY_FAIL_FAST=false
# json object, for example: {"version":"v1","zone":"cn"}
PROJECT_APPROVAL_NACOS_DISCOVERY_METADATA=

# management UI access
PROJECT_APPROVAL_ADMIN_USERNAME=admin
PROJECT_APPROVAL_ADMIN_PASSWORD=admin123

# LLM approval
# Use an OpenAI-compatible endpoint, for example:
# https://api.openai.com/v1
# https://dashscope.aliyuncs.com/compatible-mode/v1
PROJECT_APPROVAL_LLM_BASE_URL=
PROJECT_APPROVAL_LLM_API_KEY=
PROJECT_APPROVAL_LLM_MODEL=
PROJECT_APPROVAL_LLM_TIMEOUT=90
PROJECT_APPROVAL_LLM_VERIFY_SSL=true
